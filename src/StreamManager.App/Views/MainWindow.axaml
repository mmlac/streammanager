<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StreamManager.App.ViewModels"
        xmlns:views="using:StreamManager.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="900"
        x:Class="StreamManager.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900" Height="900"
        Title="StreamManager"
        Icon="/Assets/streammanager.png">

    <Window.Resources>
        <Thickness x:Key="SectionMargin">0,0,0,16</Thickness>
        <Thickness x:Key="FieldMargin">0,0,0,8</Thickness>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Border.chip">
            <Setter Property="Background" Value="#1F4A90E2" />
            <Setter Property="BorderBrush" Value="#4A90E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,4,4" />
        </Style>
        <!-- Live indicator dot colours per design.md §8. -->
        <Style Selector="Ellipse.live-dot">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Fill" Value="#888888" />
        </Style>
        <Style Selector="Ellipse.live-dot.live">
            <Setter Property="Fill" Value="#2ecc71" />
        </Style>
        <Style Selector="Ellipse.live-dot.notlive">
            <Setter Property="Fill" Value="#888888" />
        </Style>
        <Style Selector="Ellipse.live-dot.failed">
            <Setter Property="Fill" Value="#e0a020" />
        </Style>
    </Window.Styles>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:FirstRunSetupViewModel">
            <views:FirstRunSetupView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <!-- First-run wizard: shown instead of the main shell until a client is configured. -->
        <ContentControl Content="{Binding FirstRunViewModel}"
                        IsVisible="{Binding IsFirstRun}"/>

        <!-- Main shell: visible once a client is configured. -->
        <DockPanel IsVisible="{Binding !IsFirstRun}">
            <!-- Top bar -->
            <Border DockPanel.Dock="Top" Padding="12,8" Background="#11000000">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="StreamManager" FontWeight="Bold" VerticalAlignment="Center"/>

                    <!-- Live indicator (green / grey / amber per §8). -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                Margin="12,0,0,0" VerticalAlignment="Center"
                                ToolTip.Tip="{Binding FetchErrorMessage}">
                        <Ellipse Classes="live-dot"
                                 Classes.live="{Binding IsLiveIndicatorLive}"
                                 Classes.notlive="{Binding IsLiveIndicatorNotLive}"
                                 Classes.failed="{Binding IsLiveIndicatorFailed}"/>
                        <TextBlock Text="{Binding LiveIndicatorText}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <views:ConnectAccountView Grid.Column="2" Margin="16,0"
                                              DataContext="{Binding ConnectAccount}"/>

                    <Button Grid.Column="3" Content="Refresh" Margin="0,0,8,0"
                            Command="{Binding RefreshCommand}"/>
                    <Button Grid.Column="4" Content="⚙ Settings" IsEnabled="False"/>
                </Grid>
            </Border>

            <!-- Preset action bar (§8). Picker list lives inside the Flyout. -->
            <Border DockPanel.Dock="Top" Padding="12,8"
                    DataContext="{Binding PresetActions}"
                    x:DataType="vm:PresetActionsViewModel">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Load preset ▾">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Grid RowDefinitions="Auto,Auto" MinWidth="240">
                                    <TextBlock Grid.Row="0"
                                               Opacity="0.7"
                                               Margin="8,4"
                                               IsVisible="{Binding !LoadPicker.HasPresets}"
                                               Text="No presets saved yet."/>
                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding LoadPicker.Presets}"
                                                  x:Name="PresetRows">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                                    <Button Grid.Column="0"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Content="{Binding Name}"
                                                            Command="{Binding #PresetRows.((vm:PresetActionsViewModel)DataContext).LoadPicker.LoadCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Grid.Column="1"
                                                            Content="×"
                                                            Padding="6,2"
                                                            ToolTip.Tip="Delete this preset"
                                                            Command="{Binding #PresetRows.((vm:PresetActionsViewModel)DataContext).LoadPicker.DeleteCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Content="Save as preset…"
                            Command="{Binding SaveAsCommand}"/>
                    <Button Content="{Binding UpdateButtonText}"
                            Command="{Binding UpdateCurrentCommand}"
                            IsVisible="{Binding ShowUpdateButton}"/>
                </StackPanel>
            </Border>

            <!-- Bottom bar: status + Apply -->
            <Border DockPanel.Dock="Bottom" Padding="12,8" Background="#11000000">
                <StackPanel Spacing="6">
                    <!-- Error card surfaced on Apply failure (§6.6 step 6).
                         Non-dismissible per design — stays until next Apply
                         clears it. The card spans the full width so a long
                         message wraps cleanly. -->
                    <Border IsVisible="{Binding ApplyErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="#33d04040"
                            BorderBrush="#d04040"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6">
                        <TextBlock Text="{Binding ApplyErrorMessage}"
                                   TextWrapping="Wrap"/>
                    </Border>
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StreamForm.DirtyStatusLine}"
                                   VerticalAlignment="Center"/>
                        <!-- Step label + spinner only visible while the
                             orchestrator is running. -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                    Margin="0,0,12,0" VerticalAlignment="Center"
                                    IsVisible="{Binding IsApplying}">
                            <ProgressBar IsIndeterminate="True" Width="80" Height="6"/>
                            <TextBlock Text="{Binding ApplyStepLabel}" Opacity="0.8"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Apply to live stream ▶"
                                Command="{Binding ApplyCommand}"
                                IsEnabled="{Binding CanApply}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer>
                <StackPanel Margin="16" DataContext="{Binding StreamForm}"
                            x:DataType="vm:StreamFormViewModel">

                    <!-- Basics -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Basics"/>

                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Title"/>
                            <TextBox Grid.Column="1" Text="{Binding Title}"/>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Description" VerticalAlignment="Top"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Description}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="100"/>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Category"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding CategoryId, FallbackValue='—', TargetNullValue='—'}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Opacity="0.5" VerticalAlignment="Center"
                                           Text="(dropdown populated in slice 6)"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Tags" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <ItemsControl ItemsSource="{Binding Tags}" x:Name="TagsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="x:String">
                                            <Border Classes="chip">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                    <Button Content="×" Padding="4,0"
                                                            Command="{Binding #TagsList.((vm:StreamFormViewModel)DataContext).RemoveTagCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                    <TextBox Grid.Column="0"
                                             x:Name="TagInput"
                                             Text="{Binding PendingTagInput}"
                                             PlaceholderText="Type a tag and press Enter">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter"
                                                        Command="{Binding AddPendingTagCommand}"/>
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <Button Grid.Column="1" Content="Add" Margin="6,0,0,0"
                                            Command="{Binding AddPendingTagCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Privacy -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Privacy"/>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Privacy"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <ComboBox ItemsSource="{Binding PrivacyStatusOptions}"
                                          SelectedItem="{Binding PrivacyStatus}"
                                          MinWidth="140"/>
                                <CheckBox IsChecked="{Binding SelfDeclaredMadeForKids}"
                                          Content="Made for kids"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Playback & DVR -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Playback &amp; DVR"/>
                        <WrapPanel>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding EnableDvr}" Content="DVR"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding EnableEmbed}" Content="Embed"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding EnableClosedCaptions}" Content="Closed captions"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding EnableAutoStart}" Content="Auto-start"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding EnableAutoStop}" Content="Auto-stop"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding RecordFromStart}" Content="Record from start"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding StartWithSlate}" Content="Start with slate"/>
                            <CheckBox Margin="0,0,16,4" IsChecked="{Binding EnableContentEncryption}" Content="Content encryption"/>
                        </WrapPanel>
                        <Grid ColumnDefinitions="140,*" Margin="0,8,0,0">
                            <TextBlock Grid.Column="0" Classes="label" Text="Captions type"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ClosedCaptionsTypeOptions}"
                                      SelectedItem="{Binding ClosedCaptionsType}"
                                      MinWidth="220"/>
                        </Grid>
                    </StackPanel>

                    <!-- Advanced -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Advanced"/>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Latency"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LatencyPreferenceOptions}"
                                      SelectedItem="{Binding LatencyPreference}"
                                      MinWidth="140"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Projection"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ProjectionOptions}"
                                      SelectedItem="{Binding Projection}"
                                      MinWidth="140"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Stereo layout"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding StereoLayoutOptions}"
                                      SelectedItem="{Binding StereoLayout}"
                                      MinWidth="140"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Stream delay (ms)"/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding BroadcastStreamDelayMs}"
                                           Minimum="0" Maximum="60000"
                                           Increment="500"
                                           MinWidth="140"/>
                        </Grid>
                        <WrapPanel>
                            <CheckBox Margin="0,4,16,4" IsChecked="{Binding EnableLowLatency}" Content="Enable low latency (legacy)"/>
                            <CheckBox Margin="0,4,16,4" IsChecked="{Binding EnableMonitorStream}" Content="Monitor stream"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Scheduling -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Scheduling"/>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Start (ISO-8601)"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScheduledStartTimeText}"
                                     PlaceholderText="2026-04-23T18:00:00Z"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="End (ISO-8601)"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScheduledEndTimeText}"
                                     PlaceholderText="2026-04-23T21:00:00Z"/>
                        </Grid>
                    </StackPanel>

                    <!-- Language -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Language"/>
                        <Grid ColumnDefinitions="140,*,140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Default"/>
                            <TextBox Grid.Column="1" Text="{Binding DefaultLanguage}" PlaceholderText="en (slice 6)"/>
                            <TextBlock Grid.Column="2" Classes="label" Margin="16,0,0,0" Text="Audio"/>
                            <TextBox Grid.Column="3" Text="{Binding DefaultAudioLanguage}" PlaceholderText="en (slice 6)"/>
                        </Grid>
                    </StackPanel>

                    <!-- Thumbnail -->
                    <StackPanel Margin="{StaticResource SectionMargin}">
                        <TextBlock Classes="section" Text="Thumbnail"/>
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Local path"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center"
                                           Text="{Binding ThumbnailPath, FallbackValue='(none)', TargetNullValue='(none)'}"/>
                                <TextBlock Opacity="0.5" VerticalAlignment="Center"
                                           Text="(picker in slice 8)"/>
                            </StackPanel>
                        </Grid>
                        <!-- Remote thumbnail from the active broadcast (§6.8 "remote URL, read-only"). -->
                        <Grid ColumnDefinitions="140,*" Margin="{StaticResource FieldMargin}">
                            <TextBlock Grid.Column="0" Classes="label" Text="Live preview URL"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                       Text="{Binding RemoteThumbnailUrl, FallbackValue='(no active broadcast)', TargetNullValue='(no active broadcast)'}"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
