<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StreamManager.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="40"
             x:Class="StreamManager.App.Views.ConnectAccountView"
             x:DataType="vm:ConnectAccountViewModel">

    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <!-- Disconnected state -->
        <Button Content="Connect YouTube account"
                Command="{Binding ConnectCommand}"
                IsVisible="{Binding !IsConnected}"
                Padding="12,4"/>

        <!-- In-progress controls (shown while browser OAuth flow is open) -->
        <Button Content="Copy URL"
                Command="{Binding CopyAuthUrlCommand}"
                IsVisible="{Binding HasPendingAuthUrl}"
                ToolTip.Tip="Copy the Google sign-in URL to the clipboard for manual sign-in"
                Padding="8,4"/>
        <Button Content="Cancel"
                Command="{Binding CancelConnectCommand}"
                IsVisible="{Binding IsBusy}"
                Padding="8,4"/>

        <!-- Connected state -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsConnected}">
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="#cccccc"
                    IsVisible="{Binding AvatarUrl, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            <TextBlock Text="{Binding AccountEmail}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <Button Content="Disconnect"
                    Command="{Binding DisconnectCommand}"
                    Padding="8,4"/>
        </StackPanel>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#c62828"
                   VerticalAlignment="Center"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
    </StackPanel>
</UserControl>
