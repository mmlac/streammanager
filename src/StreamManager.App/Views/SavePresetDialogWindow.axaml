<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StreamManager.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="200"
        x:Class="StreamManager.App.Views.SavePresetDialogWindow"
        x:DataType="vm:SavePresetDialogViewModel"
        Width="380" Height="200"
        Title="Save as preset"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Save current form as a new preset"
                   FontWeight="SemiBold" FontSize="16"/>
        <TextBox Text="{Binding Name}"
                 x:Name="NameInput"
                 PlaceholderText="Preset name"
                 MaxLength="80">
            <TextBox.KeyBindings>
                <KeyBinding Gesture="Enter" Command="{Binding ConfirmCommand}"/>
            </TextBox.KeyBindings>
        </TextBox>
        <TextBlock Text="A preset with this name already exists — confirming will replace it."
                   IsVisible="{Binding NameMatchesExisting}"
                   TextWrapping="Wrap"
                   Opacity="0.8"
                   Foreground="#CCCCCC"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="12,4"/>
            <Button Content="Save" Command="{Binding ConfirmCommand}" Padding="12,4"
                    Classes="accent"/>
        </StackPanel>
    </StackPanel>
</Window>
